# Optional name for this session. Peers address you by this.
# If unset, a random name like "agent-a1b2" is generated. Rename anytime
# with the set_name tool from inside the session.
AGENTBUS_NAME=

# Optional override for the shared bus directory.
# Default: ~/.agentbus
AGENTBUS_HOME=

# Optional Trigger (PULL) implementation: unset = file-watch (default), or "poll".
AGENTBUS_TRIGGER=
