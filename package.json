{
  "name": "agentbus",
  "version": "0.2.0",
  "description": "A local message bus for AI agent sessions — pluggable triggers (pull) + MCP delivery (push).",
  "license": "MIT",
  "type": "module",
  "bin": { "agentbus": "./cli.ts" },
  "scripts": {
    "start": "bun install --no-summary && bun adapters/claude-mcp/server.ts",
    "agentbus": "bun cli.ts",
    "test": "bun test",
    "demo": "bun scripts/demo.ts",
    "db:generate": "drizzle-kit generate",
    "doctor": "bun cli.ts doctor",
    "setup": "bash scripts/install.sh",
    "uninstall": "bun cli.ts uninstall"
  },
  "keywords": [
    "agent",
    "claude",
    "claude-code",
    "channel",
    "mcp",
    "ipc",
    "message-bus",
    "a2a"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "drizzle-orm": "^0.45.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "drizzle-kit": "^0.31.10"
  }
}
