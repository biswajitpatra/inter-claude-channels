{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "types": ["bun"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": true
  },
  "include": ["core/**/*.ts", "triggers/**/*.ts", "adapters/**/*.ts", "cli.ts", "scripts/**/*.ts", "test/**/*.ts"]
}
